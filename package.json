{
  "name": "navis",
  "version": "2.0.10",
  "description": "Navis - RPG Map Sharing System",
  "bugs": {
    "url": "https://github.com/axdevmin/navis/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/axdevmin/navis/.git"
  },
  "license": "ISC",
  "author": "apclary",
  "main": "app.js",
  "bin": "bin/navis",
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build:frontend": "node scripts/copy-monaco-editor-files.js && npm run relay-compiler && vite build --base=./",
    "build:backend": "tsc --project server/tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "compile": "npx caxa -i . --exclude '*' '.*' '!server-build' '!build' '!package.json' '!package-lock.json' '!node_modules' -o bin/navis-bin -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/server-build/index.js\" \"--caxa\"",
    "compile:win": "npx caxa -i . --exclude '*' '.*' '!server-build' '!build' '!package.json' '!package-lock.json' '!node_modules' -o bin/navis-bin.exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/server-build/index.js\" \"--caxa\"",
    "eslint": "eslint --ignore-path .gitignore --max-warnings 0 \"**/*.js\" \"bin/navis\"",
    "postinstall": "patch-package",
    "setup": "npm run write-schema && npm run relay-compiler",
    "start": "node ./bin/navis",
    "test": "jest --passWithNoTests",
    "dev": "npm run start:server:dev & npm run start:frontend:dev",
    "start:frontend:dev": "vite",
    "start:server:dev": "ts-node-dev --project server/tsconfig.json --no-deps server/index.ts",
    "relay-compiler": "relay-compiler --schema type-definitions.graphql --src src --language typescript",
    "write-schema": "ts-node --project ./server/tsconfig.json  ./scripts/write-graphql-schema.ts",
    "patch-package": "patch-package"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@airjp73/dice-notation": "2.2.2",
    "@graphql-yoga/subscription": "0.0.2-canary-7506883.0",
    "@n1ru4l/graphql-live-query": "0.9.0",
    "@n1ru4l/graphql-live-query-patch-jsondiffpatch": "0.7.0",
    "@n1ru4l/in-memory-live-query-store": "0.8.0",
    "@n1ru4l/push-pull-async-iterable-iterator": "3.1.0",
    "@n1ru4l/socket-io-graphql-server": "0.12.0",
    "body-parser": "^1.20.3",
    "connect-busboy": "^1.0.0",
    "express": "^4.22.1",
    "fp-ts": "2.11.5",
    "framer-motion": "^4.1.17",
    "fs-extra": "9.1.0",
    "gqtx": "^0.8.1-e6f907e5.0",
    "graphql": "15.6.1",
    "io-ts": "2.2.16",
    "junk": "3.1.0",
    "liquidjs": "^10.25.7",
    "lodash": "^4.18.1",
    "morgan": "^1.10.1",
    "sanitize-html": "^2.17.3",
    "serve-favicon": "2.5.0",
    "showdown": "1.9.1",
    "socket.io": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "unzipper": "0.10.11"
